{
  "expo": {
    "name": "BiomicsHub",
    "slug": "biomicshub-app",
    "version": "1.0.33",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "biomicshubapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biomicshub.app",
      "infoPlist": {
        "NSCameraUsageDescription": "BiomicsHub uses your camera so you can take part in live classes.",
        "NSMicrophoneUsageDescription": "BiomicsHub uses your microphone so you can speak in live classes.",
        "NSPhotoLibraryUsageDescription": "BiomicsHub needs photo access so you can set a profile picture."
      }
    },
    "android": {
      "package": "com.biomicshub.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 31,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0b1220"
      },
      "permissions": [
        "POST_NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#3dd6c6",
          "defaultChannel": "biomicshub_alerts_v2"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BiomicsHub to access your photos so you can set a profile picture."
        }
      ],
      "expo-asset",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
