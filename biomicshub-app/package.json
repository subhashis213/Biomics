{
  "name": "biomicshub-app",
  "main": "index.js",
  "version": "1.0.37",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android --clean && node scripts/patch-android-for-playstore.mjs && npm run generate:notification-icon",
    "patch:android": "node scripts/patch-android-for-playstore.mjs",
    "playstore:keystore": "bash scripts/create-playstore-keystore.sh",
    "sync:google-services": "cp google-services.json android/app/google-services.json",
    "build:apk": "npm run sync:google-services && cd android && NODE_ENV=production ./gradlew assembleRelease",
    "build:aab": "cd android && NODE_ENV=production ./gradlew bundleRelease",
    "build:playstore": "npm run patch:android && npm run build:aab && node scripts/copy-playstore-aab.mjs",
    "check:google-oauth": "node scripts/check-google-oauth.mjs",
    "generate:notification-icon": "node scripts/generate-notification-icon.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@notifee/react-native": "^9.1.8",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-firebase/app": "^21.14.0",
    "@react-native-firebase/messaging": "^21.14.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.0.14",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-device": "~7.0.3",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-image-picker": "~16.0.6",
    "expo-intent-launcher": "~12.0.2",
    "expo-linking": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "react-native-youtube-iframe": "^2.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  },
  "private": true
}
